@model IEnumerable<OrderModel>

@{
	ViewData["Title"] = "Hồ sơ cá nhân";
}

<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
	<h1 class="text-center text-white display-6">Quản lý tài khoản</h1>
	<ol class="breadcrumb justify-content-center mb-0">
		<li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
		<li class="breadcrumb-item active text-white">Quản lý tài khoản</li>
	</ol>
</div>
<!-- Single Page Header End -->

<!-- Profile Content Start -->
<div class="container py-5">
	<div class="row g-4">
		<!-- Sidebar Navigation -->
		<div class="col-lg-3">
			<div class="card border-0 shadow-sm rounded-3 mb-4">
				<div class="card-body text-center p-4">
					<div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
						<i class="fas fa-user-circle text-secondary" style="font-size: 80px;"></i>
					</div>
					<h5 class="mb-1 text-truncate" title="@ViewBag.UserEmail">@ViewBag.UserEmail</h5>
					<p class="text-muted small mb-0">Thành viên</p>
				</div>
				<div class="list-group list-group-flush rounded-bottom pb-2">
					<a href="#orders" data-bs-toggle="list" class="list-group-item list-group-item-action active border-0 py-3">
						<i class="fas fa-file-invoice fa-fw text-primary me-2"></i> Đơn hàng của tôi
					</a>
					<a href="#wishlist" data-bs-toggle="list" class="list-group-item list-group-item-action border-0 py-3">
						<i class="fas fa-heart fa-fw text-danger me-2"></i> Sản phẩm yêu thích
					</a>
					<a href="#compare" data-bs-toggle="list" class="list-group-item list-group-item-action border-0 py-3">
						<i class="fas fa-exchange-alt fa-fw text-info me-2"></i> Sản phẩm so sánh
					</a>
					<a href="#addressbook" data-bs-toggle="list" class="list-group-item list-group-item-action border-0 py-3">
						<i class="fas fa-map-marker-alt fa-fw text-success me-2"></i> Cứu địa chỉ
					</a>
					<a asp-action="Edit" asp-controller="Account" class="list-group-item list-group-item-action border-0 py-3">
						<i class="fas fa-cog fa-fw text-secondary me-2"></i> Cài đặt tài khoản
					</a>
					<a asp-action="Logout" asp-controller="Account" class="list-group-item list-group-item-action border-0 py-3 text-danger">
						<i class="fas fa-sign-out-alt fa-fw me-2"></i> Đăng xuất
					</a>
				</div>
			</div>
		</div>

		<!-- Main Content Area -->
		<div class="col-lg-9">
			<div class="tab-content">
				
				<!-- Tab: Đơn hàng -->
				<div class="tab-pane fade show active" id="orders">
					<div class="d-flex justify-content-between align-items-center mb-4">
						<h4 class="mb-0 fw-bold">Đơn hàng của tôi</h4>
					</div>

					@if (Model != null && Model.Any())
					{
						foreach (var item in Model)
						{
							<div class="card border-0 shadow-sm rounded-3 mb-4">
								<div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
									<strong class="text-dark">Đơn hàng: #@item.OrderCode</strong>
									<div class="d-flex align-items-center gap-3">
										<span class="badge @(item.Status == 0 ? "bg-success" : item.Status == 2 ? "bg-danger" : "bg-warning text-dark") px-3 py-2 rounded-pill">
											@(item.Status == 0 ? "Hoàn thành" : item.Status == 1 ? "Chờ duyệt" : item.Status == 3 ? "Đang chuẩn bị" : item.Status == 4 ? "Đang giao" : "Đã huỷ")
										</span>
									</div>
								</div>
								
								<div class="card-body p-4">
									<div class="row align-items-center mb-4">
										<div class="col-md-6 mb-3 mb-md-0">
											<p class="mb-1 text-muted"><i class="far fa-calendar-alt text-primary me-2"></i><strong>Ngày đặt:</strong> @item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</p>
											<p class="mb-1 text-muted"><i class="far fa-credit-card text-success me-2"></i><strong>Thanh toán:</strong> @item.PaymentMethod</p>
											<p class="mb-0 text-muted"><i class="fas fa-truck text-info me-2"></i><strong>Phí vận chuyển:</strong> @item.ShippingCode.ToString("#,##0 VND")</p>
										</div>
										<div class="col-md-6 text-md-end">
											@if (item.Status == 1)
											{
												<a onclick="return confirm('Bạn có chắc chắn muốn huỷ đơn hàng này không?')" asp-action="CancelOrder" asp-controller="Account" asp-route-code="@item.OrderCode" class="btn btn-outline-danger btn-sm rounded-pill px-4">Huỷ đơn hàng</a>
											}
										</div>
									</div>

									<!-- Nút và Timeline -->
									@if (item.Status != 2)
									{
										<div class="position-relative mt-5 mb-2 px-md-4">
											<div class="progress" style="height: 4px;">
												@{
													int progressValue = item.Status == 1 ? 15 : item.Status == 3 ? 50 : item.Status == 4 ? 85 : item.Status == 0 ? 100 : 0;
												}
												<div class="progress-bar bg-success" role="progressbar" style="width: @progressValue%" aria-valuenow="@progressValue" aria-valuemin="0" aria-valuemax="100"></div>
											</div>
											<div class="d-flex justify-content-between text-center position-absolute w-100" style="top: -20px; left: 0;">
												<!-- Step 1 -->
												<div style="width: 25%; position: relative;">
													<div class="rounded-circle @(item.Status >= 1 || item.Status == 0 ? "bg-success" : "bg-light text-muted border border-2") text-white mx-auto d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; z-index: 2;">
														<i class="fas fa-clipboard-list fs-5"></i>
													</div>
													<small class="d-block mt-3 @(item.Status >= 1 || item.Status == 0 ? "text-success fw-bold" : "text-muted")">Chờ duyệt</small>
													@if(item.ApprovedDate.HasValue) { <small class="text-muted d-block" style="font-size:11px;">@item.ApprovedDate?.ToString("dd/MM HH:mm")</small> }
												</div>
												<!-- Step 2 -->
												<div style="width: 25%; position: relative;">
													<div class="rounded-circle @(item.Status >= 3 || item.Status == 0 ? "bg-success" : "bg-light text-muted border border-2") text-white mx-auto d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; z-index: 2;">
														<i class="fas fa-box-open fs-5"></i>
													</div>
													<small class="d-block mt-3 @(item.Status >= 3 || item.Status == 0 ? "text-success fw-bold" : "text-muted")">Chuẩn bị</small>
													@if(item.PreparedDate.HasValue) { <small class="text-muted d-block" style="font-size:11px;">@item.PreparedDate?.ToString("dd/MM HH:mm")</small> }
												</div>
												<!-- Step 3 -->
												<div style="width: 25%; position: relative;">
													<div class="rounded-circle @(item.Status >= 4 || item.Status == 0 ? "bg-success" : "bg-light text-muted border border-2") text-white mx-auto d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; z-index: 2;">
														<i class="fas fa-shipping-fast fs-5"></i>
													</div>
													<small class="d-block mt-3 @(item.Status >= 4 || item.Status == 0 ? "text-success fw-bold" : "text-muted")">Đang giao</small>
													@if(item.DeliveredDate.HasValue && item.Status == 4) { <small class="text-muted d-block" style="font-size:11px;">@item.DeliveredDate?.ToString("dd/MM HH:mm")</small> }
												</div>
												<!-- Step 4 -->
												<div style="width: 25%; position: relative;">
													<div class="rounded-circle @(item.Status == 0 ? "bg-success" : "bg-light text-muted border border-2") text-white mx-auto d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; z-index: 2;">
														<i class="fas fa-check fs-5"></i>
													</div>
													<small class="d-block mt-3 @(item.Status == 0 ? "text-success fw-bold" : "text-muted")">Hoàn thành</small>
													@if(item.Status == 0 && item.DeliveredDate.HasValue) { <small class="text-muted d-block" style="font-size:11px;">@item.DeliveredDate?.ToString("dd/MM HH:mm")</small> }
												</div>
											</div>
										</div>
									}
								</div>
							</div>
						}
					}
					else
					{
						<div class="text-center py-5 bg-light rounded-3">
							<div class="display-1 text-muted mb-3"><i class="fas fa-box-open"></i></div>
							<h5 class="text-muted">Bạn chưa có đơn hàng nào</h5>
							<a href="/" class="btn btn-primary rounded-pill mt-3 px-4 text-white">Mua sắm ngay</a>
						</div>
					}
				</div>

				<!-- Tab: Yêu thích (Wishlist) -->
				<div class="tab-pane fade" id="wishlist">
					<h4 class="mb-4 fw-bold">Sản phẩm yêu thích</h4>
					@if (ViewBag.Wishlist != null)
					{
						<div class="row g-4">
							@foreach (var item in ViewBag.Wishlist)
							{
								<div class="col-md-6 col-lg-6 col-xl-4">
									<div class="card border-0 shadow-sm rounded-3 h-100 position-relative">
										<!-- Nút xóa -->
										<a onclick="return confirm('Bạn có xác nhận muốn xoá không?')" asp-action="DeteleWishlist" asp-controller="Account" asp-route-id="@item.Wishlist.Id" class="btn btn-sm btn-danger rounded-circle position-absolute" style="top: 10px; right: 10px; z-index: 10;"><i class="fas fa-times"></i></a>
										
										<img src="~/media/products/@item.Product.Image" class="card-img-top p-3 rounded-4" style="height: 200px; object-fit: contain;" alt="@item.Product.Name">
										<div class="card-body d-flex flex-column text-center pt-0">
											<h6 class="card-title text-truncate">@item.Product.Name</h6>
											<h5 class="text-primary fw-bold mb-3">@item.Product.Price.ToString("#,##0 VND")</h5>
											<a asp-action="Detail" asp-controller="Product" asp-route-Id="@item.Product.Id" class="btn btn-outline-primary rounded-pill mt-auto">Xem chi tiết</a>
										</div>
									</div>
								</div>
							}
						</div>
					}
					else
					{
						<p class="text-center text-muted col-12 my-4">Chưa có sản phẩm yêu thích.</p>
					}
				</div>

				<!-- Tab: So sánh (Compare) -->
				<div class="tab-pane fade" id="compare">
					<h4 class="mb-4 fw-bold">Sản phẩm so sánh</h4>
					@if (ViewBag.Compare != null)
					{
						<div class="row g-4">
							@foreach (var item in ViewBag.Compare)
							{
								<div class="col-md-6 col-lg-6 col-xl-4">
									<div class="card border-0 shadow-sm rounded-3 h-100 position-relative">
										<!-- Nút xóa -->
										<a onclick="return confirm('Bạn có xác nhận muốn xoá không?')" asp-action="DeteleCompare" asp-controller="Account" asp-route-id="@item.Compare.Id" class="btn btn-sm btn-danger rounded-circle position-absolute" style="top: 10px; right: 10px; z-index: 10;"><i class="fas fa-times"></i></a>
										
										<img src="~/media/products/@item.Product.Image" class="card-img-top p-3 rounded-4" style="height: 200px; object-fit: contain;" alt="@item.Product.Name">
										<div class="card-body d-flex flex-column text-center pt-0">
											<h6 class="card-title text-truncate">@item.Product.Name</h6>
											<h5 class="text-primary fw-bold mb-3">@item.Product.Price.ToString("#,##0 VND")</h5>
											<a asp-action="Detail" asp-controller="Product" asp-route-Id="@item.Product.Id" class="btn btn-outline-primary rounded-pill mt-auto">Xem chi tiết</a>
										</div>
									</div>
								</div>
							}
						</div>
					}
					else  
					{
						<p class="text-center text-muted col-12 my-4">Chưa có sản phẩm so sánh.</p>
					}
				</div>

				<!-- Tab: Sổ địa chỉ -->
				<div class="tab-pane fade" id="addressbook">
					<div class="d-flex justify-content-between align-items-center mb-4">
						<h4 class="mb-0 fw-bold">Sổ địa chỉ</h4>
						<button class="btn btn-primary rounded-pill text-white px-4" data-bs-toggle="modal" data-bs-target="#addAddressModal"><i class="fas fa-plus me-2"></i>Thêm địa chỉ</button>
					</div>

					<div class="row g-4">
						@if(ViewBag.Addresses != null) {
							foreach(var addr in ViewBag.Addresses) {
								<div class="col-md-6">
									<div class="card h-100 border-0 shadow-sm rounded-3 @(addr.IsDefault ? "border-primary shadow" : "")" style="@(addr.IsDefault ? "border: 2px solid var(--bs-primary) !important;" : "")">
										<div class="card-body">
											<div class="d-flex justify-content-between mb-3">
												<h6 class="fw-bold mb-0">@addr.FullName</h6>
												@if(addr.IsDefault) { 
													<span class="badge bg-danger rounded-pill"><i class="fas fa-check-circle me-1"></i> Mặc định</span> 
												}
											</div>
											<p class="text-muted mb-2"><i class="fas fa-phone-alt fa-fw me-2"></i>@addr.PhoneNumber</p>
											<p class="text-muted mb-4"><i class="fas fa-map-marker-alt fa-fw me-2"></i>@addr.DetailedAddress, @addr.Phuong, @addr.Quan, @addr.Tinh</p>
											
											<div class="d-flex gap-2 mt-auto pt-3 border-top">
												@if(!addr.IsDefault) {
													<form asp-action="SetDefaultAddress" asp-controller="Account" asp-route-id="@addr.Id" method="post" class="flex-grow-1">
														<button type="submit" class="btn btn-sm btn-outline-primary w-100 rounded-pill">Đặt mặc định</button>
													</form>
												}
												<form asp-action="DeleteAddress" asp-controller="Account" asp-route-id="@addr.Id" method="post" class="flex-grow-1" onsubmit="return confirm('Xác nhận xóa?')">
													<button type="submit" class="btn btn-sm btn-outline-danger w-100 rounded-pill"><i class="fas fa-trash-alt me-1"></i> Xóa</button>
												</form>
											</div>
										</div>
									</div>
								</div>
							}
						}
					</div>
				</div>

			</div>
		</div>
	</div>
</div>

<!-- Address Book Modal -->
<div class="modal fade" id="addAddressModal" tabindex="-1" aria-labelledby="addAddressModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content border-0 shadow rounded-3">
			<form asp-action="AddAddress" asp-controller="Account" method="post">
				<div class="modal-header border-bottom-0 pt-4 pb-0 px-4">
					<h5 class="modal-title fw-bold" id="addAddressModalLabel">Thêm địa chỉ mới</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body p-4">
					<div class="mb-3">
						<label class="form-label text-muted small fw-bold text-uppercase">Họ Tên</label>
						<input type="text" class="form-control" name="FullName" required>
					</div>
					<div class="mb-3">
						<label class="form-label text-muted small fw-bold text-uppercase">Số điện thoại</label>
						<input type="tel" class="form-control" name="PhoneNumber" required>
					</div>
					<div class="row g-3 mb-3">
						<div class="col-sm-6">
							<label class="form-label text-muted small fw-bold text-uppercase">Tỉnh / Thành phố</label>
							<select class="form-select" id="modal-tinh" name="Tinh" required>
								<option value="">Chọn Tỉnh Thành</option>
							</select>
						</div>
						<div class="col-sm-6">
							<label class="form-label text-muted small fw-bold text-uppercase">Quận / Huyện</label>
							<select class="form-select" id="modal-quan" name="Quan" required>
								<option value="">Chọn Quận Huyện</option>
							</select>
						</div>
					</div>
					<div class="mb-3">
						<label class="form-label text-muted small fw-bold text-uppercase">Phường / Xã</label>
						<select class="form-select" id="modal-phuong" name="Phuong" required>
							<option value="">Chọn Phường Xã</option>
						</select>
					</div>
					<div class="mb-3">
						<label class="form-label text-muted small fw-bold text-uppercase">Địa chỉ cụ thể</label>
						<textarea class="form-control" name="DetailedAddress" rows="2" placeholder="Số nhà, tên đường..." required></textarea>
					</div>
					<div class="form-check mt-3">
						<input class="form-check-input" type="checkbox" name="IsDefault" value="true" id="isDefaultCheck">
						<label class="form-check-label text-dark" for="isDefaultCheck">
							Đặt làm địa chỉ mặc định
						</label>
					</div>
				</div>
				<div class="modal-footer border-top-0 px-4 pb-4 pt-0">
					<button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Trở lại</button>
					<button type="submit" class="btn btn-primary rounded-pill px-4 text-white">Lưu địa chỉ</button>
				</div>
			</form>
		</div>
	</div>
</div>
<!-- Profile Page End -->

@section Scripts {
	<script>
		$(document).ready(function() {
			// Lấy tỉnh thành cho Modal Address
			$.getJSON('https://esgoo.net/api-tinhthanh/1/0.htm', function(data_tinh) {
				if (data_tinh.error == 0) {
					$.each(data_tinh.data, function(key_tinh, val_tinh) {
						$("#modal-tinh").append('<option value="' + val_tinh.full_name + '" data-id="' + val_tinh.id + '">' + val_tinh.full_name + '</option>');
					});
					$("#modal-tinh").change(function(e) {
						var idtinh = $(this).find(':selected').data('id');
						// Lấy quận huyện
						$.getJSON('https://esgoo.net/api-tinhthanh/2/' + idtinh + '.htm', function(data_quan) {
							if (data_quan.error == 0) {
								$("#modal-quan").html('<option value="">Chọn Quận Huyện</option>');
								$("#modal-phuong").html('<option value="">Chọn Phường Xã</option>');
								$.each(data_quan.data, function(key_quan, val_quan) {
									$("#modal-quan").append('<option value="' + val_quan.full_name + '" data-id="' + val_quan.id + '">' + val_quan.full_name + '</option>');
								});
								// Lấy phường xã
								$("#modal-quan").change(function(e) {
									var idquan = $(this).find(':selected').data('id');
									$.getJSON('https://esgoo.net/api-tinhthanh/3/' + idquan + '.htm', function(data_phuong) {
										if (data_phuong.error == 0) {
											$("#modal-phuong").html('<option value="">Chọn Phường Xã</option>');
											$.each(data_phuong.data, function(key_phuong, val_phuong) {
												$("#modal-phuong").append('<option value="' + val_phuong.full_name + '">' + val_phuong.full_name + '</option>');
											});
										}
									});
								});
							}
						});
					});
				}
			});
		});
	</script>
}
