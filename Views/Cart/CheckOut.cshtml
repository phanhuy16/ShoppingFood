@model ShoppingFood.Models.ViewModel.CartItemViewModel
@{
	ViewData["Title"] = "Checkout";
	var user = ViewBag.User as AppUserModel;
	var addresses = ViewBag.Addresses as IEnumerable<ShoppingFood.Models.UserAddressModel>;
}
<!-- Custom Style for Checkout -->
<style>
    .checkout-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        padding: 30px;
        border: none;
    }
    .payment-method-card {
        cursor: pointer;
        border: 2px solid #eaeaea;
        border-radius: 10px;
        transition: all 0.3s ease;
        padding: 15px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .payment-method-card:hover {
        border-color: #b0e566;
    }
    .payment-method-card.selected {
        border-color: #81c408;
        background-color: #f8fff0;
        box-shadow: 0 4px 12px rgba(129, 196, 8, 0.15);
    }
    .payment-method-card input[type="radio"] {
        display: none;
    }
    .payment-icon {
        width: 40px;
        height: 40px;
        object-fit: contain;
    }
    .address-box {
        border: 2px dashed #ccc;
        border-radius: 10px;
        padding: 20px;
        background: #fafafa;
    }
    .address-modal-card {
        border: 2px solid #eee;
        border-radius: 8px;
        padding: 15px;
        cursor: pointer;
        transition: 0.2s;
    }
    .address-modal-card.selected {
        border-color: #81c408;
        background: #f8fff0;
    }
    .address-modal-card input[type="radio"] {
        display: none;
    }
</style>

<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
	<h1 class="text-center text-white display-6">Thông tin giao hàng</h1>
	<ol class="breadcrumb justify-content-center mb-0">
		<li class="breadcrumb-item"><a href="#">Home</a></li>
		<li class="breadcrumb-item active text-white">Thanh toán</li>
	</ol>
</div>
<!-- Single Page Header End -->

<div class="container py-5">
    <div class="row g-5">
        <!-- Chuyên mục Thông tin & Thanh toán -->
        <div class="col-lg-7">
            <!-- 1. Địa chỉ giao hàng -->
            <div class="checkout-card mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="mb-0"><i class="fas fa-map-marker-alt text-primary me-2"></i> Địa chỉ nhận hàng</h4>
                    @if (addresses != null && addresses.Any())
                    {
                        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addressModal">Thay đổi</button>
                    }
                </div>
                
                <div id="selectedAddressDisplay" class="address-box mb-3">
                    @if (addresses != null && addresses.Any())
                    {
                        var defaultAddress = addresses.FirstOrDefault(a => a.IsDefault) ?? addresses.First();
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="mb-1 fw-bold" id="displayFullName">@defaultAddress.FullName</h6>
                                <p class="mb-1 text-muted" id="displayPhone"><i class="fas fa-phone-alt fs-6 me-1"></i> @defaultAddress.PhoneNumber</p>
                                <p class="mb-0 text-muted" id="displayAddress"><i class="fas fa-home fs-6 me-1"></i> @defaultAddress.DetailedAddress, @defaultAddress.Phuong, @defaultAddress.Quan, @defaultAddress.Tinh</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3">
                            <i class="fas fa-map-marked-alt display-4 text-muted mb-3"></i>
                            <p>Bạn chưa có địa chỉ nào trong sổ lưu.</p>
                            <a asp-action="Profile" asp-controller="Account" class="btn btn-primary rounded-pill">Quản lý Sổ địa chỉ</a>
                        </div>
                    }
                </div>

                <!-- Form Gốc chứa field ẩn -->
                <div class="@(addresses != null && addresses.Any() ? "d-none" : "d-block") mt-4">
                    <h6 class="mb-3 border-bottom pb-2">Nhập địa chỉ thủ công (nếu không dùng Sổ)</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Họ và tên *</label>
                            <input type="text" id="FullName" class="form-control" value="@(addresses != null && addresses.Any() ? "" : user.UserName)" name="FullName">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số điện thoại *</label>
                            <input type="tel" id="Mobile" class="form-control" value="@(addresses != null && addresses.Any() ? "" : user.PhoneNumber)" name="Mobile">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Địa chỉ chi tiết *</label>
                            <input type="text" id="Address" class="form-control" placeholder="Số nhà, tên đường..." name="Address">
                        </div>
                    </div>
                </div>

                <div class="col-12 mt-4">
                    <label class="form-label text-muted">Ghi chú cho đơn hàng (Tùy chọn)</label>
                    <textarea id="OrderNotes" class="form-control" rows="3" placeholder="Ví dụ: Giao hàng vào giờ hành chính..."></textarea>
                </div>
            </div>

            <!-- 2. Phương thức thanh toán -->
            <div class="checkout-card">
                <h4 class="mb-4"><i class="fas fa-wallet text-primary me-2"></i> Phương thức Thanh toán</h4>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="payment-method-card selected w-100">
                            <input type="radio" name="tempPaymentMethod" value="cod" checked>
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;"><i class="fas fa-truck text-success fs-5"></i></div>
                            <div>
                                <h6 class="mb-0">Thanh toán khi nhận hàng</h6>
                                <small class="text-muted">COD</small>
                            </div>
                        </label>
                    </div>
                    <div class="col-md-6">
                        <label class="payment-method-card w-100">
                            <input type="radio" name="tempPaymentMethod" value="qr">
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;"><i class="fas fa-qrcode text-primary fs-5"></i></div>
                            <div>
                                <h6 class="mb-0">Chuyển khoản VietQR</h6>
                                <small class="text-muted">Quét mã nhanh chóng</small>
                            </div>
                        </label>
                    </div>
                    <div class="col-md-6">
                        <label class="payment-method-card w-100">
                            <input type="radio" name="tempPaymentMethod" value="vnpay">
                            <img src="~/images/vnpay_logo.png" onerror="this.onerror=null; this.src='https://vnpay.vn/s1/statics.vnpay.vn/2023/9/06ncktiwd6dc1694418189687.png'" class="payment-icon" alt="VNPay">
                            <div>
                                <h6 class="mb-0">Ví VNPay</h6>
                            </div>
                        </label>
                    </div>
                    <div class="col-md-6">
                        <label class="payment-method-card w-100">
                            <input type="radio" name="tempPaymentMethod" value="momo">
                            <img src="~/images/momo_logo.png" onerror="this.onerror=null; this.src='https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.png'" class="payment-icon" alt="Momo">
                            <div>
                                <h6 class="mb-0">Ví MoMo</h6>
                            </div>
                        </label>
                    </div>
                    <div class="col-md-6">
                        <label class="payment-method-card w-100">
                            <input type="radio" name="tempPaymentMethod" value="paypal">
                            <img src="~/images/paypal_logo.png" onerror="this.onerror=null; this.src='https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg'" class="payment-icon" style="width:50px" alt="Paypal">
                            <div>
                                <h6 class="mb-0">PayPal</h6>
                            </div>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chuyên mục Đơn hàng -->
        <div class="col-lg-5">
            <div class="checkout-card" style="position: sticky; top: 20px;">
                <h4 class="mb-4">Tóm tắt đơn hàng</h4>
                <div class="table-responsive mb-4">
                    <table class="table border-0 text-start align-middle">
                        <tbody>
                            @foreach (var item in Model.CartItems)
                            {
                                <tr>
                                    <td class="ps-0" style="width: 60px;">
                                        <div class="position-relative">
                                            <img src="~/media/products/@item.Image" class="img-fluid rounded" style="width: 50px; height: 50px; object-fit: cover;" alt="">
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@item.Quantity</span>
                                        </div>
                                    </td>
                                    <td>
                                        <p class="mb-0 fw-bold">@item.ProductName</p>
                                    </td>
                                    <td class="text-end pe-0">
                                        <p class="mb-0 fw-bold">@((item.Quantity * item.Price).ToString("#,##0 VND"))</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="border-bottom pb-3 mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính</span>
                        <span class="fw-bold" id="uiSubTotal" data-value="@Model.GrandTotal">@Model.GrandTotal.ToString("#,##0 VND")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Phí vận chuyển</span>
                        <span class="fw-bold text-danger" id="uiShippingCost">+ @Model.ShippingCost.ToString("#,##0 VND")</span>
                    </div>
                </div>
                <div class="d-flex justify-content-between mb-4">
                    <h5 class="fw-bold mb-0">Tổng tiền</h5>
                    <h4 class="fw-bold text-primary mb-0" id="uiGrandTotal">@((Model.GrandTotal + Model.ShippingCost).ToString("#,##0 VND"))</h4>
                </div>
                
                <!-- Action Buttons Container -->
                <div id="checkoutActionContainer">
                    <!-- COD / QR Form -->
                    <form id="mainCheckoutForm" asp-action="CheckOut" asp-controller="Cart" method="post" style="display: block;">
                        <input type="hidden" name="paymentMethod" id="formPaymentMethod" value="COD" />
                        <input type="hidden" name="paymentId" value="" />
                        <!-- Bắt lại các field Address ẩn để POST đi -->
                        <input type="hidden" name="FullName" id="postFullName" value="@(user.UserName)" />
                        <input type="hidden" name="Mobile" id="postMobile" value="@(user.PhoneNumber)" />
                        <input type="hidden" name="Address" id="postAddress" value="" />
                        <button type="button" id="btnPlaceOrder" class="btn btn-primary rounded-pill w-100 py-3 fw-bold fs-5 text-uppercase">Đặt hàng</button>
                    </form>

                    <!-- VNPay Form -->
                    <form id="vnpayForm" asp-action="PaymentVnPay" asp-controller="Payment" method="post" style="display: none;">
                        <input type="hidden" name="Name" value="@User.Identity.Name" />
                        <input type="hidden" name="Amount" value="@Model.GrandTotal" />
                        <input type="hidden" name="OrderDescription" value="Thanh toán VnPay cho đơn hàng tại ShoppingFood" />
                        <input type="hidden" name="OrderType" value="other" />
                        <button type="submit" class="btn btn-primary rounded-pill w-100 py-3 fw-bold fs-5 text-uppercase">Thanh toán qua VNPay</button>
                    </form>

                    <!-- MoMo Form -->
                    <form id="momoForm" asp-action="PaymentMomo" asp-controller="Payment" method="post" style="display: none;">
                        <input type="hidden" name="Amount" value="@Model.GrandTotal" />
                        <input type="hidden" name="OrderInfo" value="Thanh toán Momo cho đơn hàng" />
                        <input type="hidden" name="FullName" value="@User.Identity.Name" />
                        <button type="submit" name="PayUrl" class="btn btn-primary rounded-pill w-100 py-3 fw-bold fs-5 text-uppercase">Thanh toán qua MoMo</button>
                    </form>

                    <!-- PayPal Container -->
                    <div id="paypal-button-container" class="mt-2" style="display: none;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Chọn Địa Chỉ -->
<div class="modal fade" id="addressModal" tabindex="-1" aria-labelledby="addressModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold" id="addressModalLabel">Chọn địa chỉ giao hàng</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        @if (addresses != null)
        {
            foreach (var addr in addresses)
            {
                <label class="address-modal-card d-block mb-3 @(addr.IsDefault ? "selected" : "")">
                    <input type="radio" name="addressSelection" value="@addr.Id" 
                           data-name="@addr.FullName" 
                           data-phone="@addr.PhoneNumber" 
                           data-address="@addr.DetailedAddress, @addr.Phuong, @addr.Quan, @addr.Tinh"
                           data-tinh="@addr.Tinh"
                           data-quan="@addr.Quan"
                           data-phuong="@addr.Phuong"
                           @(addr.IsDefault ? "checked" : "")>
                    <div class="d-flex align-items-center">
                        <i class="fas fa-check-circle text-success me-3 fs-4 d-none icon-check"></i>
                        <div class="w-100">
                            <div class="d-flex justify-content-between">
                                <span class="fw-bold">@addr.FullName</span>
                                @if(addr.IsDefault) { <span class="badge bg-danger rounded-pill">Mặc định</span> }
                            </div>
                            <small class="text-muted d-block mt-1">@addr.PhoneNumber</small>
                            <small class="text-secondary d-block mt-1">@addr.DetailedAddress, @addr.Phuong, @addr.Quan, @addr.Tinh</small>
                        </div>
                    </div>
                </label>
            }
        }
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Trở lại</button>
        <button type="button" class="btn btn-primary rounded-pill px-4" id="btnConfirmAddress" data-bs-dismiss="modal">Xác nhận</button>
      </div>
    </div>
  </div>
</div>

<script src="https://www.paypal.com/sdk/js?client-id=@ViewBag.PaypalClientId"></script>
@section Scripts {
    <script>
        $(document).ready(function() {
            // == 1. Logic cho phần Địa chỉ ==
            
            // Hàm đồng bộ data từ form/modal vào hidden inputs
            function syncAddressData(name, phone, address) {
                $('#displayFullName').text(name);
                $('#displayPhone').html('<i class="fas fa-phone-alt fs-6 me-1"></i> ' + phone);
                $('#displayAddress').html('<i class="fas fa-home fs-6 me-1"></i> ' + address);
                
                $('#FullName').val(name);
                $('#Mobile').val(phone);
                $('#Address').val(address);

                $('#postFullName').val(name);
                $('#postMobile').val(phone);
                $('#postAddress').val(address);
            }

            function calculateShipping(tinh, quan, phuong) {
                if(!tinh || !quan || !phuong) return;
                $.ajax({
                    type: 'POST',
                    url: "@Url.Action("GetShipping", "Cart")",
                    data: { tinh: tinh, quan: quan, phuong: phuong },
                    success: function (response) {
                        if (response.success) {
                            var price = response.price;
                            var subtotal = parseFloat($('#uiSubTotal').data('value')) || 0;
                            var total = subtotal + price;
                            
                            var formatCurrency = function(num) {
                                return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",") + " VND";
                            };
                            
                            $('#uiShippingCost').text('+ ' + formatCurrency(price));
                            $('#uiGrandTotal').text(formatCurrency(total));
                        }
                    }
                });
            }

            // On load: nếu có address select sẵn
            var checkedAddr = $('input[name="addressSelection"]:checked');
            if(checkedAddr.length > 0) {
                syncAddressData(checkedAddr.data('name'), checkedAddr.data('phone'), checkedAddr.data('address'));
                calculateShipping(checkedAddr.data('tinh'), checkedAddr.data('quan'), checkedAddr.data('phuong'));
            }

            // UI Modal Change color
            $('input[name="addressSelection"]').change(function(){
                $('.address-modal-card').removeClass('selected');
                $('.address-modal-card .icon-check').addClass('d-none');
                
                var parent = $(this).closest('.address-modal-card');
                parent.addClass('selected');
                parent.find('.icon-check').removeClass('d-none');
            });

            // Confirm inside Modal
            $('#btnConfirmAddress').click(function() {
                var selected = $('input[name="addressSelection"]:checked');
                if (selected.length > 0) {
                    syncAddressData(selected.data('name'), selected.data('phone'), selected.data('address'));
                    calculateShipping(selected.data('tinh'), selected.data('quan'), selected.data('phuong'));
                }
            });

            // Gõ vào ô text thì đồng bộ hidden field
            $('#FullName').keyup(function(){ $('#postFullName').val($(this).val()); });
            $('#Mobile').keyup(function(){ $('#postMobile').val($(this).val()); });
            $('#Address').keyup(function(){ $('#postAddress').val($(this).val()); });


            // == 2. Logic cho phần Phương thức thanh toán ==
            $('input[name="tempPaymentMethod"]').change(function() {
                // Update UI Card
                $('.payment-method-card').removeClass('selected');
                $(this).closest('.payment-method-card').addClass('selected');

                var method = $(this).val();
                
                // Hide all form buttons
                $('#mainCheckoutForm, #vnpayForm, #momoForm, #paypal-button-container').hide();

                if (method === 'vnpay') {
                    $('#vnpayForm').show();
                } else if (method === 'momo') {
                    $('#momoForm').show();
                } else if (method === 'paypal') {
                    $('#paypal-button-container').show();
                } else {
                    // cod and qr use the same main form but different hidden method
                    $('#mainCheckoutForm').show();
                    if(method === 'qr') {
                        $('#formPaymentMethod').val('QR');
                        $('#btnPlaceOrder').text('Xác nhận chuyển khoản QR');
                    } else {
                        $('#formPaymentMethod').val('COD');
                        $('#btnPlaceOrder').text('Đặt hàng COD');
                    }
                }
            });

            // Submit master form
            $('#btnPlaceOrder').click(function(){
                // Validation if manual address
                if($('#postFullName').val() == '' || $('#postMobile').val() == '' || $('#postAddress').val() == '') {
                    alert('Vui lòng nhập đầy đủ thông tin giao hàng!');
                    return;
                }
                
                // Hiển thị Loader
                $('#spinner').addClass('show');
                
                // Disable button để tránh double submit
                $(this).prop('disabled', true).text('Đang xử lý...');

                // Submit form
                $('#mainCheckoutForm').submit();
            });

            // Gắn sự kiện loading cho VNPay và Momo form
            $('#vnpayForm, #momoForm').on('submit', function() {
                $('#spinner').addClass('show');
                $(this).find('button[type="submit"]').prop('disabled', true).text('Đang chuyển hướng...');
            });
        });

        // Paypal config
        paypal.Buttons({
            style: {
                disableMaxHeight: true,
            },
        }).render('#paypal-button-container');
    </script>
}