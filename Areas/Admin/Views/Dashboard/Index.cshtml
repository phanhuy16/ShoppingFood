@model StatisticalModel
@{
	ViewData["Title"] = "Dashboard";
}

<main>
	<div class="container-fluid px-4">
		<h1 class="mt-4">Dashboard</h1>
		<ol class="breadcrumb mb-4">
			<li class="breadcrumb-item active">Dashboard</li>
		</ol>
		<div class="row">
			<div class="col-xl col-md">
				<div class="card bg-primary text-white mb-4">
					<div class="card-body">
						<h6>Sản phẩm</h6>
						<p class="mb-0">Số lượng: @ViewBag.CountProduct</p>
					</div>
					<div class="card-footer d-flex align-items-center justify-content-between">
						<a class="small text-white stretched-link" asp-action="Index" asp-controller="Product">Xem chi tiết</a>
						<div class="small text-white"><i class="fas fa-angle-right"></i></div>
					</div>
				</div>
			</div>
			<div class="col-xl col-md">
				<div class="card bg-warning text-white mb-4">
					<div class="card-body">
						<h6>Người dùng</h6>
						<p class="mb-0">Số lượng: @ViewBag.CountUser</p>
					</div>
					<div class="card-footer d-flex align-items-center justify-content-between">
						<a class="small text-white stretched-link" asp-action="Index" asp-controller="User">Xem chi tiết</a>
						<div class="small text-white"><i class="fas fa-angle-right"></i></div>
					</div>
				</div>
			</div>
			<div class="col-xl col-md">
				<div class="card bg-info text-white mb-4">
					<div class="card-body">
						<h6>Đơn hàng</h6>
						<p class="mb-0">Số lượng: @ViewBag.CountOrder</p>
					</div>
					<div class="card-footer d-flex align-items-center justify-content-between">
						<a class="small text-white stretched-link" asp-action="Index" asp-controller="Order">Xem chi tiết</a>
						<div class="small text-white"><i class="fas fa-angle-right"></i></div>
					</div>
				</div>
			</div>
			<div class="col-xl col-md">
				<div class="card bg-success text-white mb-4">
					<div class="card-body">
						<h6>Danh mục</h6>
						<p class="mb-0">Số lượng: @ViewBag.CountCategory</p>
					</div>
					<div class="card-footer d-flex align-items-center justify-content-between">
						<a class="small text-white stretched-link" asp-action="Index" asp-controller="Category">Xem chi tiết</a>
						<div class="small text-white"><i class="fas fa-angle-right"></i></div>
					</div>
				</div>
			</div>
			<div class="col-xl col-md">
				<div class="card bg-success text-white mb-4">
					<div class="card-body">
						<h6>Danh mục sản phẩm</h6>
						<p class="mb-0">Số lượng: @ViewBag.CountProCate</p>
					</div>
					<div class="card-footer d-flex align-items-center justify-content-between">
						<a class="small text-white stretched-link" asp-action="Index" asp-controller="ProductCategory">Xem chi tiết</a>
						<div class="small text-white"><i class="fas fa-angle-right"></i></div>
					</div>
				</div>
			</div>
		</div>
		<div class="row my-4">
			<div class="col-md-4">
				<h6>Lọc dữ liệu</h6>
				<select class="form-select form-select-sm filter-select" aria-label="Small select example">
					<option selected> --- Lọc dữ liệu --- </option>
					<option value="7">7 ngày trước</option>
					<option value="30">1 tháng trước</option>
					<option value="90">3 tháng trước</option>
					<option value="365">1 năm trước</option>
				</select>
			</div>
			<div class="col-md-8">
				<span class="h6">Tuỳ chọn: </span>
				<div class="form-group">
					<label class="form-label">Từ ngày</label>
					<input type="date" class="form-control-sm" id="date_form" asp-for="@Model.CreatedDate" />
					<label class="form-label">Đến ngày</label>
					<input type="date" class="form-control-sm" id="date_to" asp-for="@Model.CreatedDate" />
					<button id="btnFilter" class="ms-2 btn btn-sm btn-primary">Filter</button>
				</div>
			</div>
		</div>
		<div class="mt-5">
			<h6>Thống kê biểu đồ</h6>
			<div id="myfirstchart" style="height: 250px;"></div>

			<h6>Bảng thống kê chi tiết</h6>
			<div class="card mb-4">
				<div class="card-body">
					<table id="datatablesDashboard" class="table table-striped table-bordered">
						<thead>
							<tr>
								<th>Ngày</th>
								<th>Đơn hàng</th>
								<th>Sản phẩm bán</th>
								<th>Doanh thu</th>
								<th>Lợi nhuận</th>
							</tr>
						</thead>
						<tbody id="statisticalTableBody">
							<!-- Data will be populated via AJAX -->
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</main>

@section Scripts {
	<script>
		$(document).ready(function(){
			// Initialize DataTable once
			var statisticalTable = new DataTable('#datatablesDashboard', {
				layout: {
					topStart: {
						buttons: ['copy', 'csv', 'excel', 'pdf', 'print']
					}
				},
				order: [[0, 'desc']],
				language: {
					emptyTable: "Không có dữ liệu hiển thị",
					zeroRecords: "Không tìm thấy dữ liệu phù hợp"
				}
			});

			var ChartMorris = new Morris.Line({
				element: 'myfirstchart',
				data: [],
				xkey: 'date',
				ykeys: ['sold', 'quantity', 'revenue', 'profit'],
				labels: ["Số lượng bán", 'Đơn hàng', 'Doanh thu', 'Lợi nhuận'],
				hideHover: 'auto',
				resize: true
			});

			function updateDashboard(data) {
				if (!data || data.length === 0) {
					ChartMorris.setData([]);
					statisticalTable.clear().draw();
					return;
				}

				// Update Chart
				var chartData = data.map(function(item){
					return {
						date: item.date || item.Date,
						sold: item.sold || item.Sold || 0,
						quantity: item.quantity || item.Quantity || 0,
						revenue: item.revenue || item.Revenue || 0,
						profit: item.profit || item.Profit || 0
					};
				});
				ChartMorris.setData(chartData);

				// Update Table using DataTables API
				statisticalTable.clear();
				data.forEach(function(item) {
					var dateVal = item.date || item.Date;
					var quantityVal = item.quantity || item.Quantity || 0;
					var soldVal = item.sold || item.Sold || 0;
					var revenueVal = item.revenue || item.Revenue || 0;
					var profitVal = item.profit || item.Profit || 0;

					statisticalTable.row.add([
						dateVal,
						quantityVal,
						soldVal,
						parseFloat(revenueVal).toLocaleString('vi-VN') + " VND",
						parseFloat(profitVal).toLocaleString('vi-VN') + " VND"
					]);
				});
				statisticalTable.draw();
			}

			// Initial data load
			$.ajax({
				url:"@Url.Action("GetData", "Dashboard")",
				type: 'POST',
				dataType: 'json',
				success: function(data) {
					updateDashboard(data);
				},
				error: function(error) {
					console.error("GetData Error:", error);
				}
			});

			$('.filter-select').on('change', function(){
				var days = $(this).val();
				if (!days || isNaN(days)) return;

				var endDate = new Date();
				var startDate = new Date(endDate.getTime() - days * 24 * 60 * 60 * 1000);

				$.ajax({
					url:"@Url.Action("GetDataByDate", "Dashboard")",
					type:"POST",
					dataType: 'json',
					data:{
						startDate: startDate.toISOString().split('T')[0],
						endDate: endDate.toISOString().split('T')[0],
					},
					success: function(data) {
						updateDashboard(data);
					},
					error: function(error) {
						console.error("GetDataByDate Error:", error);
					}
				})
			});

			$('#btnFilter').click(function(){
				var fromDate = $('#date_form').val();
				var toDate = $('#date_to').val();
				
				$.ajax({
					url:"@Url.Action("FilterDate", "Dashboard")",
					type:"POST",
					dataType: 'json',
					data:{
						fromDate: fromDate,
						toDate: toDate
					},
					success: function(data) {
						updateDashboard(data);
					},
					error: function(error) {
						console.error("FilterDate Error:", error);
					}
				})
			});
		});

	</script>
}