@model ProductModel

@{
	ViewData["Title"] = "Edit Product";
}

<main>
	<div class="container-fluid px-4">
		<h1 class="mt-4">Edit product</h1>
		<ol class="breadcrumb mb-4">
			<li class="breadcrumb-item"><a asp-action="Index" asp-controller="Dashboard">Dashboard</a></li>
			<li class="breadcrumb-item active">Edit category</li>
		</ol>
		<form asp-action="Edit" method="post" enctype="multipart/form-data">
			<input type="hidden" asp-for="@Model.Id" />
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
			<div class="row">
				<div class="col-md">
					<div class="form-group">
						<label class="form-label">Name</label>
						<input asp-for="@Model.Name" class="form-control" type="text" />
						<span asp-validation-for="Name" class="text-danger"></span>
					</div>
					<div class="form-group">
						<label class="form-label">Category</label>
						<select asp-for="@Model.CategoryId" class="form-select" asp-items="ViewBag.Categories">
							<option>-- Choose a category --</option>
						</select>
						<span asp-validation-for="CategoryId" class="text-danger"></span>
					</div>
					<div class="form-group">
						<label class="form-label">Brand</label>
						<select asp-for="@Model.BrandId" class="form-select" asp-items="ViewBag.Brands">
							<option>-- Choose a brand --</option>
						</select>
						<span asp-validation-for="BrandId" class="text-danger"></span>
					</div>
					<div class="form-group">
						<label class="form-label">ProductCategory</label>
						<select asp-for="ProductCategoryId" class="form-select" asp-items="ViewBag.ProductCategories">
							<option>-- Choose a productcategory --</option>
						</select>
						<span asp-validation-for="ProductCategoryId" class="text-danger"></span>
					</div>
					<div class="form-group">
						<label class="form-label">Description</label>
						<textarea asp-for="@Model.Description" class="form-control"></textarea>
						<span asp-validation-for="Description" class="text-danger"></span>
					</div>
				</div>
				<div class="col-md">
					<div class="form-group">
						<label class="form-label">Price</label>
						<input asp-for="Price" pattern="[0-9.,]+" class="form-control typing-price" type="number" />
						<span id="price-convert" class="my-3 d-block"></span>
						<span asp-validation-for="Price" class="text-danger"></span>
					</div>
					<div class="form-group">
						<label class="form-label">PriceSale</label>
						<input asp-for="PriceSale" pattern="[0-9.,]+" class="form-control typing-priceSale" type="number" />
						<span id="priceSale-convert" class="my-3 d-block"></span>
						<span asp-validation-for="PriceSale" class="text-danger"></span>
					</div>
					<div class="form-group">
						<label class="form-label">Capital Price</label>
						<input asp-for="CapitalPrice" pattern="[0-9.,]+" class="form-control typing-capitalPrice" type="number" />
						<span id="capitalPrice-convert" class="my-3 d-block"></span>
						<span asp-validation-for="CapitalPrice" class="text-danger"></span>
					</div>
					<div class="form-group">
						<label class="form-label">Image</label>
						<!-- Hiển thị ảnh hiện tại -->
						<div class="mb-2">
							<label for="inputGroupFile01">
								<img src="~/media/products/@Model.Image" alt="@Model.Name" style="width: 120px; height: 120px; object-fit: cover; border: 1px solid #ccc; border-radius: 5px; padding: 2px;" />
								<img id="imgpreview" style="object-fit: cover; border: 1px solid #ccc; border-radius: 5px; padding: 2px;" />
							</label>
						</div>
						<!-- Upload file -->
						<input asp-for="ImageUpload" class="form-control d-none" type="file" accept="image/*" id="inputGroupFile01" />
						<span asp-validation-for="ImageUpload" class="text-danger"></span>
					</div>

					<div class="form-group">
						<label class="form-label">Status</label>
						<select asp-for="@Model.Status" class="form-select">
							<option>-- Choose a status --</option>
							<option value="1"> Hiện </option>
							<option value="0"> Ẩn </option>
						</select>
						<span asp-validation-for="Status" class="text-danger"></span>
					</div>

					<div class="form-group mb-4">
						<label class="form-label">Gallery Images</label>
						<div class="row mb-2" id="gallery-container">
							@if (Model.ProductImages != null)
							{
								foreach (var img in Model.ProductImages)
								{
									<div class="col-md-3 mb-2 text-center gallery-item">
										<img src="~/media/products/@img.ImageUrl" class="img-thumbnail" style="width: 100px; height: 100px; object-fit: cover;" />
										<button type="button" class="btn btn-danger btn-xs d-block mx-auto mt-1" onclick="removeGalleryImage(@img.Id, this)">Delete</button>
									</div>
								}
							}
						</div>
						<input asp-for="ImageGalleryUpload" class="form-control" type="file" multiple id="ImageGalleryUpload" />
						<div id="gallery-preview" class="d-flex flex-wrap gap-2 mt-2"></div>
						<span asp-validation-for="ImageGalleryUpload" class="text-danger"></span>
					</div>
				</div>
			</div>

			<div class="card my-4">
				<div class="card-header d-flex justify-content-between align-items-center">
					<h5 class="mb-0">Product Variants</h5>
					<button type="button" class="btn btn-sm btn-success" onclick="addVariant()">+ Add Variant</button>
				</div>
				<div class="card-body">
					<table class="table table-bordered" id="variants-table">
						<thead>
							<tr>
								<th>Name</th>
								<th>Value</th>
								<th>Price Plus (VND)</th>
								<th>Action</th>
							</tr>
						</thead>
						<tbody id="variants-body">
							@if (Model.ProductVariants != null)
							{
								foreach (var variant in Model.ProductVariants)
								{
									<tr>
										<td><input type="text" class="form-control v-name" value="@variant.Name" /></td>
										<td><input type="text" class="form-control v-value" value="@variant.Value" /></td>
										<td><input type="number" class="form-control v-price" value="@variant.PricePlus" /></td>
										<td><button type="button" class="btn btn-danger btn-sm" onclick="removeVariant(this)">Remove</button></td>
									</tr>
								}
							}
						</tbody>
					</table>
					<input type="hidden" asp-for="VariantJson" id="VariantJson" />
				</div>
			</div>
			<div class="form-group">
				<label class="form-label">Detail</label>
				<textarea asp-for="@Model.Detail" class="form-control"></textarea>
				<span asp-validation-for="Detail" class="text-danger"></span>
			</div>
			<div class="my-3">
				<button class="btn btn-sm btn-primary">Submit</button>
				<button class="btn btn-sm btn-outline-secondary" asp-action="Index">Cancel</button>
			</div>
		</form>
	</div>
</main>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
	<script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js" asp-append-version="true"></script>
	<script>
		CKEDITOR.replace("Detail", {
			removePlugins: "update-notifier", // Tắt thông báo cập nhật CKEditor
			disableNativeSpellChecker: false // Giữ kiểm tra chính tả nếu cần
		});

		$('#inputGroupFile01').change(function(){
			readURL(this);
		});

		$('#ImageGalleryUpload').change(function(){
			$('#gallery-preview').empty();
			if (this.files) {
				Array.from(this.files).forEach(file => {
					const reader = new FileReader();
					reader.onload = function(e) {
						$('#gallery-preview').append(`
							<div class="position-relative">
								<img src="${e.target.result}" style="width: 100px; height: 100px; object-fit: cover; border: 1px solid #ddd; border-radius: 4px;" />
							</div>
						`);
					}
					reader.readAsDataURL(file);
				});
			}
		});

		$('.typing-price').on('keyup', function(){
			var current = $(this).val();
				$('#price-convert').html(new Intl.NumberFormat('vn-VN', { style: 'currency', currency: 'VND' }).format(current));
		})

		$('.typing-capitalPrice').on('keyup', function(){
			var current = $(this).val();
				$('#capitalPrice-convert').html(new Intl.NumberFormat('vn-VN', { style: 'currency', currency: 'VND' }).format(current));
		})

		$('.typing-priceSale').on('keyup', function(){
			var current = $(this).val();
				$('#priceSale-convert').html(new Intl.NumberFormat('vn-VN', { style: 'currency', currency: 'VND' }).format(current));
		})

		function removeGalleryImage(id, btn) {
			if (confirm('Are you sure you want to delete this image?')) {
				$.post('/Admin/Product/DeleteImage', { imageId: id }, function (res) {
					$(btn).closest('.gallery-item').remove();
				}).fail(function() {
					alert('Error deleting image');
				});
			}
		}

		function addVariant() {
			const row = `
				<tr>
					<td><input type="text" class="form-control v-name" placeholder="Size" /></td>
					<td><input type="text" class="form-control v-value" placeholder="L" /></td>
					<td><input type="number" class="form-control v-price" value="0" /></td>
					<td><button type="button" class="btn btn-danger btn-sm" onclick="removeVariant(this)">Remove</button></td>
				</tr>
			`;
			$('#variants-body').append(row);
		}

		function removeVariant(btn) {
			$(btn).closest('tr').remove();
		}

		$('form').submit(function () {
			const variants = [];
			$('#variants-body tr').each(function () {
				const name = $(this).find('.v-name').val();
				const value = $(this).find('.v-value').val();
				const price = $(this).find('.v-price').val();
				if (name && value) {
					variants.push({
						Name: name,
						Value: value,
						PricePlus: parseFloat(price) || 0
					});
				}
			});
			$('#VariantJson').val(JSON.stringify(variants));
		});
	</script>
}